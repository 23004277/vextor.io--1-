rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string
        && id.size() > 0
        && id.size() <= 128
        && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUserStats(stats) {
      return stats is map
        && stats.keys().hasAll([
          'totalGames',
          'totalScore',
          'highScore',
          'maxLevel',
          'totalKills',
          'totalDeaths',
          'eliteKills',
          'transformations',
          'highestEliteDamage',
          'achievementsUnlocked',
          'questsUnlocked'
        ])
        && stats.keys().hasOnly([
          'totalGames',
          'totalScore',
          'highScore',
          'maxLevel',
          'totalKills',
          'totalDeaths',
          'eliteKills',
          'transformations',
          'highestEliteDamage',
          'achievementsUnlocked',
          'questsUnlocked'
        ])
        && stats.totalGames is int && stats.totalGames >= 0
        && stats.totalScore is int && stats.totalScore >= 0
        && stats.highScore is int && stats.highScore >= 0
        && stats.maxLevel is int && stats.maxLevel >= 1 && stats.maxLevel <= 999
        && stats.totalKills is int && stats.totalKills >= 0
        && stats.totalDeaths is int && stats.totalDeaths >= 0
        && stats.eliteKills is int && stats.eliteKills >= 0
        && stats.transformations is int && stats.transformations >= 0
        && stats.highestEliteDamage is int && stats.highestEliteDamage >= 0
        && stats.achievementsUnlocked is list
        && stats.achievementsUnlocked.size() <= 300
        && stats.questsUnlocked is list
        && stats.questsUnlocked.size() <= 300;
    }

    function isValidUser(data) {
      return data is map
        && data.keys().hasAll([
          'username',
          'createdAt',
          'currency',
          'inventory',
          'equippedItem',
          'unlockedEliteSkins',
          'supportTotal',
          'supporterRank',
          'stats'
        ])
        && data.keys().hasOnly([
          'username',
          'createdAt',
          'currency',
          'inventory',
          'equippedItem',
          'unlockedEliteSkins',
          'supportTotal',
          'supporterRank',
          'stats'
        ])
        && data.username is string
        && data.username.size() >= 3
        && data.username.size() <= 32
        && data.createdAt is timestamp
        && data.currency is int
        && data.currency >= 0
        && data.currency <= 999999999
        && data.inventory is list
        && data.inventory.size() > 0
        && data.inventory.size() <= 300
        && data.equippedItem is string
        && data.equippedItem.size() <= 128
        && data.unlockedEliteSkins is list
        && data.unlockedEliteSkins.size() <= 300
        && data.supportTotal is int
        && data.supportTotal >= 0
        && data.supporterRank is string
        && (
          data.supporterRank == 'standard'
          || data.supporterRank == 'rank1'
          || data.supporterRank == 'rank2'
          || data.supporterRank == 'rank3'
        )
        && isValidUserStats(data.stats);
    }

    function isValidNewUser(data) {
      return isValidUser(data)
        && data.createdAt == request.time
        && data.supportTotal == 0
        && data.supporterRank == 'standard';
    }

    function isValidUserUpdate(data) {
      return isValidUser(data)
        && data.username == resource.data.username
        && data.createdAt == resource.data.createdAt
        && data.supportTotal == resource.data.supportTotal
        && data.supporterRank == resource.data.supporterRank
        && data.diff(resource.data).affectedKeys().hasOnly([
          'stats',
          'currency',
          'inventory',
          'equippedItem',
          'unlockedEliteSkins'
        ]);
    }

    function isValidHighScore(data) {
      return data is map
        && data.keys().hasAll([
          'name',
          'score',
          'level',
          'classType',
          'date',
          'userId'
        ])
        && data.keys().hasOnly([
          'name',
          'score',
          'level',
          'classType',
          'date',
          'userId'
        ])
        && data.name is string
        && data.name.size() >= 3
        && data.name.size() <= 32
        && data.score is int
        && data.score >= 0
        && data.score <= 999999999
        && data.level is int
        && data.level >= 1
        && data.level <= 999
        && data.classType is string
        && data.classType.size() >= 1
        && data.classType.size() <= 64
        && data.userId is string
        && data.userId == request.auth.uid
        && data.date is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);

      allow create: if isOwner(userId)
        && isValidNewUser(request.resource.data);

      allow update: if isOwner(userId)
        && isValidUserUpdate(request.resource.data);

      allow delete: if false;
      allow list: if false;
    }

    match /highScores/{scoreId} {
      allow get, list: if true;

      allow create: if isSignedIn()
        && scoreId == request.auth.uid
        && isValidHighScore(request.resource.data)
        && request.resource.data.date == request.time
        && isValidId(scoreId);

      allow update: if isSignedIn()
        && scoreId == request.auth.uid
        && resource.data.userId == request.auth.uid
        && isValidHighScore(request.resource.data)
        && request.resource.data.date == request.time
        && request.resource.data.score > resource.data.score
        && request.resource.data.userId == resource.data.userId;

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
