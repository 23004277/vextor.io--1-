{
  "name": "vextor.io",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node -e \"const fs=require('fs'); fs.rmSync('dist',{ recursive:true, force:true });\"",
    "build": "vite build && node -e \"const fs=require('fs'); try{ fs.unlinkSync('dist/_redirects'); }catch(e){}\"",
    "announce:update": "node scripts/post-discord-update.mjs",
    "build:announce": "npm run build && npm run announce:update",
    "preview": "npm run build && wrangler dev",
    "lint": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "deploy:announce": "npm run build:announce && wrangler deploy"
  },
  "dependencies": {
    "@google/genai": "^1.37.0",
    "@types/pixi.js": "^4.8.9",
    "firebase": "^12.13.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.6.0",
    "motion": "^12.38.0",
    "pixi.js": "^8.18.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.95.0"
  }
}