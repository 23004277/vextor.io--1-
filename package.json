{
  "name": "vextor.io",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A single-player tactical arcade shooter merging deep .io upgrade paths with multidimensional chaos, Rebirth tier classes, cosmic anomalies, AI battles, bosses, and high-speed survival.",
  "scripts": {
    "dev": "vite",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{ recursive:true, force:true });\"",
    "prebuild": "npm run clean",
    "build": "vite build && node -e \"const fs=require('fs'); try{ fs.unlinkSync('dist/_redirects'); }catch(e){}\"",
    "lint": "tsc --noEmit",
    "announce:update": "node scripts/post-discord-update.mjs",
    "build:announce": "npm run build && npm run announce:update",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "deploy:announce": "npm run build:announce && wrangler deploy"
  },
  "dependencies": {
    "@types/pixi.js": "^4.8.9",
    "firebase": "^12.13.0",
    "lucide-react": "^1.6.0",
    "motion": "^12.38.0",
    "pixi.js": "^8.18.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.95.0"
  }
}
